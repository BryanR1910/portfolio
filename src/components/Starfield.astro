<canvas id="starfield" aria-hidden="true"></canvas>

<script>
  (function() {
  const canvas = document.getElementById('starfield');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  let stars = [];
  let mouseX = 0;
  let mouseY = 0;

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }

  function initStars(count = 120) {
    stars = [];
    for (let i = 0; i < count; i++) {
      const isHero = Math.random() < 0.08;
      stars.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        size: isHero ? 1.4 + Math.random() * 1.2 : 0.3 + Math.random() * 1.0,
        baseOpacity: isHero ? 0.35 + Math.random() * 0.35 : 0.08 + Math.random() * 0.28,
        speed: 0.04 + Math.random() * 0.16,
        swayAmp: 0.2 + Math.random() * 0.5,
        swayFreq: 0.08 + Math.random() * 0.15,
        phase: Math.random() * Math.PI * 2,
        twinkleFreq: 0.15 + Math.random() * 0.5,
        twinkleAmp: isHero ? 0.3 + Math.random() * 0.3 : 0.1 + Math.random() * 0.4,
      });
    }
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    const time = performance.now() / 1000;
    const parallaxX = (mouseX / window.innerWidth - 0.5) * 3;
    const parallaxY = (mouseY / window.innerHeight - 0.5) * 3;

    for (const star of stars) {
      // Upward drift
      star.y -= star.speed * 0.6;

      // Horizontal sway — smooth sine oscillation
      star.x += Math.sin(time * star.swayFreq + star.phase) * star.swayAmp * 0.05;

      // Wrap around
      if (star.y < -10) {
        star.y = canvas.height + 10;
        star.x = Math.random() * canvas.width;
      }
      if (star.x < -10) star.x = canvas.width + 10;
      if (star.x > canvas.width + 10) star.x = -10;

      // Mouse parallax (applied on top)
      const dx = star.x + parallaxX * star.speed * 1.5;
      const dy = star.y + parallaxY * star.speed * 1.5;

      // Twinkle
      const twinkle = 0.5 + 0.5 * Math.sin(time * star.twinkleFreq + star.phase);
      const alpha = star.baseOpacity * (0.7 + 0.3 * (1 - star.twinkleAmp) + star.twinkleAmp * twinkle);

      ctx.beginPath();
      ctx.arc(dx, dy, star.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(226, 221, 217, ${alpha})`;
      ctx.fill();

      // Very subtle glow for hero stars
      if (star.size > 2) {
        ctx.beginPath();
        ctx.arc(dx, dy, star.size * 2.5, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(226, 221, 217, ${alpha * 0.06})`;
        ctx.fill();
      }
    }

    requestAnimationFrame(draw);
  }

  window.addEventListener('resize', () => {
    resize();
    initStars();
  });

  window.addEventListener('mousemove', (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
  });

  resize();
  initStars();
  draw();
  })();
</script>

<style is:global>
  #starfield {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.7;
  }

  /* Push content above the starfield */
  .section-shell {
    position: relative;
    z-index: 1;
  }

  main {
    position: relative;
    z-index: 1;
  }
</style>
