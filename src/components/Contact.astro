---
import { contactLinks, profile } from '../content/portfolio';
---

<section id="contacto" class="section-shell" aria-labelledby="contact-title">
  <div class="surface-card rounded-[2rem] p-6 sm:p-10">
    <p class="eyebrow">Contacto</p>
    <h2 id="contact-title" class="display-heading mt-3 text-3xl font-semibold text-[#f4f0ea] sm:text-5xl">Hablemos de tu próximo backend</h2>
    <p class="mt-5 max-w-2xl leading-7 text-[#a8b3c7]">
      Si necesitás una API, integración o base backend mantenible, podés contactarme por cualquiera de estos canales estáticos.
    </p>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {contactLinks.map((link) => (
        <a class="muted-card block rounded-2xl p-5 transition hover:border-[#d8ebe7]/50 hover:bg-white/[0.07]" href={link.href} aria-label={`${link.label}: ${link.description}`}>
          <span class="font-semibold text-[#f4f0ea]">{link.label}</span>
          <span class="mt-2 block text-sm leading-6 text-[#a8b3c7]">{link.description}</span>
          {link.placeholder && <span class="mt-3 block text-xs text-[#6f7d95]">Placeholder reemplazable</span>}
        </a>
      ))}
    </div>
    <a class="link-focus mt-8 inline-flex rounded-full bg-[#d8ebe7] px-5 py-3 text-sm font-bold text-[#080b12] transition hover:bg-[#f0f7f4]" href={profile.cvHref}>
      {profile.cvLabel}
    </a>
  </div>
</section>
